interfaces/whatsapp/node_modules/
interfaces/whatsapp/package-lock.json

# Runtime state files
data/*_state.json
data/*_sync_state.json

# Generated content
data/audio/
data/static/
data/learning.db
data/tasks.db

# Backups
backups/

# Loose media in root
*.jpg
*.jpeg
*.png

# Theme assets ship with the codebase — un-ignore them.
!services/roen-minimal/assets/img/*.jpg
!services/roen-minimal/assets/img/*.jpeg
!services/roen-minimal/assets/img/*.png

# Claude agent/skill configs
.agents/
.claude/skills/


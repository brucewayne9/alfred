ORACLE_AUDIT_*.md

.superpowers/
.worktrees/

# AG manual screenshot toolchain — local cookies + node_modules + temp shots
scripts/ag_manuals/.cookies.json
scripts/ag_manuals/node_modules/
scripts/ag_manuals/screenshots/


# YouTube session cookies — secret, never commit
config/youtube_cookies.txt

# Central Casting runtime data (library DB, voice clips, previews)
data/casting.db
data/casting/
